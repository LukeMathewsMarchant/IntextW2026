# Copy to .env in the repository root (two levels above backend/Lighthouse.Web). Loaded in Development only.

# Supabase / PostgreSQL (Npgsql connection string). Replace YOUR_PROJECT with your project ref — do not leave the placeholder or DNS will fail.
# Local Postgres example: Host=127.0.0.1;Port=5432;Database=postgres;Username=postgres;Password=postgres
ConnectionStrings__DefaultConnection=Host=YOUR_PROJECT.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# Optional: seed an initial Admin user (12+ char password per policy)
Seed__AdminEmail=admin@example.com
Seed__AdminPassword=ChangeMe123456!

# Supabase project (reference / client-side if needed)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# ASP.NET
ASPNETCORE_ENVIRONMENT=Development

# Frontend (Vite): set for deployed static frontend to call hosted ASP.NET API/MVC
# Example: https://your-api-host.example.com
VITE_API_URL=

# Optional SMTP settings for email-based 2FA codes
SMTP_HOST=
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
